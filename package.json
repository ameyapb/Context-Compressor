{
  "name": "context-compressor",
  "displayName": "Context Compressor",
  "description": "Count GPT-4 tokens in the active file",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-compressor.countTokens",
        "title": "Context Compressor: Count Tokens in File"
      },
      {
        "command": "context-compressor.selectModel",
        "title": "Context Compressor: Select Model"
      },
      {
        "command": "context-compressor.countFolderTokens",
        "title": "Context Compressor: Count Tokens"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "context-compressor.countFolderTokens",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "gpt-tokenizer": "^2.1.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0"
  }
}
