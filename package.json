  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-compressor.countTokens",
        "title": "Count Tokens in File"
      }
    ]
  },
  "dependencies": {
    "gpt-tokenizer": "^2.1.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0"
  }
}
