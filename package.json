{
  "name": "token-budget-builder",
  "displayName": "Token Budget Builder",
  "description": "Assemble, compress, and copy multi-file prompts — with live token budget for any model",
  "version": "0.1.0",
  "publisher": "Uchiha-Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameyapb/context-compressor"
  },
  "bugs": {
    "url": "https://github.com/ameyapb/context-compressor/issues"
  },
  "keywords": [
    "token counter",
    "llm",
    "context",
    "compression",
    "prompt",
    "gpt",
    "claude",
    "ai"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "token-budget-builder-sidebar",
          "title": "Context Compressor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "token-budget-builder-sidebar": [
        {
          "id": "token-budget-builder-files",
          "name": "Context Files",
          "checkboxes": true
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "token-budget-builder-files",
        "contents": "No files in context yet.\n\nRight-click any file or folder in the Explorer and choose **Add to Context**, or use the button above to browse.\n\n[Add Files](command:token-budget-builder.addToContext)"
      }
    ],
    "commands": [
      {
        "command": "token-budget-builder.countTokens",
        "title": "Context Compressor: Count Tokens in File"
      },
      {
        "command": "token-budget-builder.selectModel",
        "title": "Context Compressor: Select Model"
      },
      {
        "command": "token-budget-builder.countFolderTokens",
        "title": "Context Compressor: Count Tokens in Selection"
      },
      {
        "command": "token-budget-builder.addToContext",
        "title": "Add to Context",
        "icon": "$(add)"
      },
      {
        "command": "token-budget-builder.removeFromContext",
        "title": "Remove from Context",
        "icon": "$(trash)"
      },
      {
        "command": "token-budget-builder.clearContext",
        "title": "Clear Context",
        "icon": "$(clear-all)"
      },
      {
        "command": "token-budget-builder.setCompressionMode",
        "title": "Set Compression Mode",
        "icon": "$(settings-gear)"
      },
      {
        "command": "token-budget-builder.assemblePrompt",
        "title": "Assemble & Copy Prompt",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "token-budget-builder.addToContext",
          "group": "z_contextcompressor@1"
        },
        {
          "command": "token-budget-builder.countFolderTokens",
          "group": "z_contextcompressor@2"
        }
      ],
      "view/title": [
        {
          "command": "token-budget-builder.assemblePrompt",
          "when": "view == token-budget-builder-files",
          "group": "navigation@1"
        },
        {
          "command": "token-budget-builder.addToContext",
          "when": "view == token-budget-builder-files",
          "group": "navigation@2"
        },
        {
          "command": "token-budget-builder.setCompressionMode",
          "when": "view == token-budget-builder-files",
          "group": "navigation@3"
        },
        {
          "command": "token-budget-builder.clearContext",
          "when": "view == token-budget-builder-files",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "token-budget-builder.removeFromContext",
          "when": "view == token-budget-builder-files && viewItem == contextFile",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "test": "mocha test/**/*.test.js"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.1.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "mocha": "^11.0.0"
  }
}
